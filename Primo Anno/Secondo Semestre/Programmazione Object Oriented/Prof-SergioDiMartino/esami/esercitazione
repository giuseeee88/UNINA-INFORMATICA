public interface Tracciabile{
    public String getStato();
}

public class Pacco implements Tracciabile{
    public String codiceId;
    public boolean consegnato;

    public Pacco(String codiceId, boolean consegnato){
        this.codiceId = codiceId;
        this.consegnato = consegnato;
    }
    @Override //questo l'ho inserito vedendo il codice corretto da te non sapevo fosse un caso di override probabilmente non ho ancora occhio
    public String getStato(){
        if (this.consegnato == true){
            return "consegnato";
        }
        else{
            return "in transito";
        }
    }
}

public class PaccoEspresso extends Pacco{
    public int oreMassime;

    public PaccoEspresso(String codiceId, boolean consegnato, int oreMassime){
        super(codiceId, consegnato);
        this.oreMassime = oreMassime;
    }
}

public class Corriere{
    public String nomeAutista;
    public List<Pacco> pacco;

    public Corriere(String nomeAutista){
        this.nomeAutista = nomeAutista;
        this.pacco = new ArrayList<Pacco>();
    }

    public void caricaPacco(Pacco p){
        this.pacco.add(p);
    }
}




