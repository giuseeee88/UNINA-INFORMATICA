public interface Consumabile{
    public double getCalorie();
}

public class Piatto implements Consumabile{
    public String nome;
    public double calorieBase;

    public Piatto(String nome, double calorieBase){
        this.nome = nome;
        this.calorieBase = calorieBase;
    }

    public double getCalorie(){
        return calorieBase;
    }
}

public class PiattoSpeciale extends Piatto{
    public double calorieExtra;

    public PiattoSpeciale(String nome, double calorieBase, double calorieExtra){
        super(nome, calorieBase);
        this.calorieExtra = calorieExtra;
    }

    @Override
    public double getCalorie(){
        return this.calorieBase + this.calorieExtra;
    }
}

public class Cliente{
    public String nome;
    public List<Piatto> piatto;

    public Cliente(String nome){
        this.nome = nome;
        this.piatto = new ArrayList<Piatto>();
    }

    public void ordinaPiatto(Piatto p){
        this.piatto.add(p);
    }
}

public class Tavolo{
    public int numeroTavolo;
    public Cliente nome;

    public Tavolo(int numeroTavolo, Cliente nome){
        this.numeroTavolo = numeroTavolo;
        this.nome = nome;
    }
}






























