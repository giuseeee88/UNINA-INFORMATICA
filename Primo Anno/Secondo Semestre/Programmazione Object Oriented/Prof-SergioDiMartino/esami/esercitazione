public interface Noleggiabile{
    public boolean isDisponibile();
}

public class Libro implements Noleggiabile{
    public String titolo;
    public boolean inPrestito;

    public Libro(String titolo, boolean inPrestito){
        this.titolo = titolo;
        this.inPrestito = inPrestito;
    }
    public boolean isDisponibile(){
        return !this.inPrestito;
    }
}

public class Utente{
    public String nome;
    public List<Libro> libro;

    public Utente(String nome){
    this.nome = nome;
    this.libro = new ArrayList<Libro>();
    }
    public void prendiInPrestito(Libro l){
        this.libro.add(l);
    }
}







