-- Vista per statistiche offerte per utente
CREATE OR REPLACE VIEW vista_statistiche_offerte_utente AS
SELECT 
    u.ID_Utente,
    u.nome,
    u.cognome,
    COUNT(DISTINCT ov.ID_Offerta) as num_offerte_vendita,
    COUNT(DISTINCT r.ID_Regalo) as num_offerte_regalo,
    COUNT(DISTINCT os.ID_Scambio) as num_offerte_scambio,
    COUNT(DISTINCT oa.ID_OffertaAccettata) as num_offerte_vendita_accettate,
    COUNT(DISTINCT ra.ID_RegaloAccettato) as num_regali_accettati,
    COUNT(DISTINCT sa.ID_ScambioAccettato) as num_scambi_accettati
FROM UTENTE u
LEFT JOIN OFFERTA_VENDITA ov ON u.ID_Utente = ov.ID_Utente_FK
LEFT JOIN REGALO r ON u.ID_Utente = r.ID_Utente_FK
LEFT JOIN OFFERTA_SCAMBIO os ON u.ID_Utente = os.ID_Utente_FK
LEFT JOIN OFFERTA_ACCETTATA oa ON ov.ID_Offerta = oa.ID_Offerta_FK
LEFT JOIN REGALO_ACCETTATO ra ON r.ID_Regalo = ra.ID_Regalo_FK
LEFT JOIN SCAMBIO_ACCETTATO sa ON os.ID_Scambio = sa.ID_Scambio_FK
GROUP BY u.ID_Utente, u.nome, u.cognome;

-- Vista per statistiche prezzi offerte vendita accettate
CREATE OR REPLACE VIEW vista_statistiche_prezzi_vendita AS
SELECT 
    u.ID_Utente,
    u.nome,
    u.cognome,
    AVG(ov.prezzo) as prezzo_medio_offerte_accettate,
    MIN(ov.prezzo) as prezzo_minimo_offerte_accettate,
    MAX(ov.prezzo) as prezzo_massimo_offerte_accettate,
    COUNT(oa.ID_OffertaAccettata) as numero_vendite_completate
FROM UTENTE u
JOIN OFFERTA_VENDITA ov ON u.ID_Utente = ov.ID_Utente_FK
JOIN OFFERTA_ACCETTATA oa ON ov.ID_Offerta = oa.ID_Offerta_FK
GROUP BY u.ID_Utente, u.nome, u.cognome;

-- Vista per annunci con numero di offerte ricevute
CREATE OR REPLACE VIEW vista_annunci_con_offerte AS
SELECT 
    a.ID_Annuncio,
    a.tipoAnnuncio,
    a.descrizione,
    a.statoAnnuncio,
    u.nome as nome_proprietario,
    u.cognome as cognome_proprietario,
    c.nomeCategoria,
    COUNT(DISTINCT ov.ID_Offerta) + 
    COUNT(DISTINCT r.ID_Regalo) + 
    COUNT(DISTINCT os.ID_Scambio) as num_offerte_totali
FROM ANNUNCIO a
JOIN UTENTE u ON a.ID_Utente_FK = u.ID_Utente
JOIN CATEGORIA c ON a.ID_Categoria_FK = c.ID_Categoria
LEFT JOIN OFFERTA_VENDITA ov ON a.ID_Annuncio = ov.ID_Annuncio_FK
LEFT JOIN REGALO r ON a.ID_Annuncio = r.ID_Annuncio_FK
LEFT JOIN OFFERTA_SCAMBIO os ON a.ID_Annuncio = os.ID_Annuncio_FK
GROUP BY a.ID_Annuncio, a.tipoAnnuncio, a.descrizione, a.statoAnnuncio, 
         u.nome, u.cognome, c.nomeCategoria;

