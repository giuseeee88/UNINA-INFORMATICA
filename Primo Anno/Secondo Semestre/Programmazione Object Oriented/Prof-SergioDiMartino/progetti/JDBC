-- ========================================
-- CREAZIONE TABELLE
-- ========================================

-- Tabella UTENTE
CREATE TABLE UTENTE (
    ID_Utente SERIAL PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    cognome VARCHAR(100) NOT NULL,
    email VARCHAR(255) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL, -- Memorizzare in forma criptata in produzione
    indirizzo VARCHAR(500),
    dataRegistrazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statusAccount VARCHAR(20) DEFAULT 'ATTIVO' CHECK (statusAccount IN ('ATTIVO', 'SOSPESO', 'RIPOSO', 'IN_VALIDAZIONE', 'CONGELATO'))
);

-- Tabella CATEGORIA
CREATE TABLE CATEGORIA (
    ID_Categoria SERIAL PRIMARY KEY,
    nomeCategoria VARCHAR(100) NOT NULL UNIQUE,
    descrizione TEXT
);

-- Tabella ANNUNCIO
CREATE TABLE ANNUNCIO (
    ID_Annuncio SERIAL PRIMARY KEY,
    tipoAnnuncio VARCHAR(20) NOT NULL CHECK (tipoAnnuncio IN ('VENDITA', 'SCAMBIO', 'REGALO')),
    descrizione TEXT NOT NULL,
    prezzo DECIMAL(10, 2) CHECK (prezzo >= 0),
    dataCreazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    modalitaConsegna TEXT,
    luogoConsegna VARCHAR(500),
    statoAnnuncio VARCHAR(20) DEFAULT 'ATTIVO' CHECK (statoAnnuncio IN ('ATTIVO', 'SCADUTO', 'RIMOSSO', 'COMPLETATO')),
    dataScadenza TIMESTAMP,
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    ID_Categoria_FK INTEGER NOT NULL REFERENCES CATEGORIA(ID_Categoria) ON DELETE RESTRICT,
    CONSTRAINT check_data_scadenza CHECK (dataScadenza IS NULL OR dataScadenza > dataCreazione),
    CONSTRAINT check_prezzo_vendita CHECK (
        (tipoAnnuncio = 'VENDITA' AND prezzo > 0) OR
        (tipoAnnuncio = 'REGALO' AND prezzo = 0) OR
        (tipoAnnuncio = 'SCAMBIO' AND (prezzo IS NULL OR prezzo = 0))
    )
);

-- Tabella OFFERTA_VENDITA
CREATE TABLE OFFERTA_VENDITA (
    ID_Offerta SERIAL PRIMARY KEY,
    prezzo DECIMAL(10, 2) NOT NULL CHECK (prezzo > 0),
    descrizione TEXT,
    dataOfferta TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statoOfferta VARCHAR(20) DEFAULT 'IN_ATTESA' CHECK (statoOfferta IN ('IN_ATTESA', 'ACCETTATA', 'RIFIUTATA', 'RITIRATA')),
    ID_Annuncio_FK INTEGER NOT NULL REFERENCES ANNUNCIO(ID_Annuncio) ON DELETE CASCADE,
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE
);

-- Tabella OFFERTA_ACCETTATA
CREATE TABLE OFFERTA_ACCETTATA (
    ID_OffertaAccettata SERIAL PRIMARY KEY,
    dataAccettazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Offerta_FK INTEGER NOT NULL UNIQUE REFERENCES OFFERTA_VENDITA(ID_Offerta) ON DELETE CASCADE
);

-- Tabella OFFERTA_RIFIUTATA
CREATE TABLE OFFERTA_RIFIUTATA (
    ID_OffertaRifiutata SERIAL PRIMARY KEY,
    dataRifiuto TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    motivoRifiuto TEXT,
    ID_Offerta_FK INTEGER NOT NULL UNIQUE REFERENCES OFFERTA_VENDITA(ID_Offerta) ON DELETE CASCADE
);

-- Tabella REGALO
CREATE TABLE REGALO (
    ID_Regalo SERIAL PRIMARY KEY,
    descrizione TEXT NOT NULL,
    dataOfferta TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statoOfferta VARCHAR(20) DEFAULT 'IN_ATTESA' CHECK (statoOfferta IN ('IN_ATTESA', 'ACCETTATA', 'RIFIUTATA', 'RITIRATA')),
    ID_Annuncio_FK INTEGER NOT NULL REFERENCES ANNUNCIO(ID_Annuncio) ON DELETE CASCADE,
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE
);

-- Tabella REGALO_ACCETTATO
CREATE TABLE REGALO_ACCETTATO (
    ID_RegaloAccettato SERIAL PRIMARY KEY,
    dataAccettazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Regalo_FK INTEGER NOT NULL UNIQUE REFERENCES REGALO(ID_Regalo) ON DELETE CASCADE
);

-- Tabella OFFERTA_SCAMBIO
CREATE TABLE OFFERTA_SCAMBIO (
    ID_Scambio SERIAL PRIMARY KEY,
    descrizione TEXT,
    dataOfferta TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statoOfferta VARCHAR(20) DEFAULT 'IN_ATTESA' CHECK (statoOfferta IN ('IN_ATTESA', 'ACCETTATA', 'RIFIUTATA', 'RITIRATA')),
    ID_Annuncio_FK INTEGER NOT NULL REFERENCES ANNUNCIO(ID_Annuncio) ON DELETE CASCADE,
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE
);

-- Tabella SCAMBIO_ACCETTATO
CREATE TABLE SCAMBIO_ACCETTATO (
    ID_ScambioAccettato SERIAL PRIMARY KEY,
    dataAccettazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Scambio_FK INTEGER NOT NULL UNIQUE REFERENCES OFFERTA_SCAMBIO(ID_Scambio) ON DELETE CASCADE
);

-- Tabella OGGETTO_PROPOSTO
CREATE TABLE OGGETTO_PROPOSTO (
    ID_OggettoProposto SERIAL PRIMARY KEY,
    descrizione TEXT NOT NULL,
    immagine VARCHAR(500),
    ID_Scambio_FK INTEGER NOT NULL REFERENCES OFFERTA_SCAMBIO(ID_Scambio) ON DELETE CASCADE
);

-- Tabella RECENSIONE
CREATE TABLE RECENSIONE (
    ID_Recensione SERIAL PRIMARY KEY,
    descrizione TEXT,
    valutazione INTEGER NOT NULL CHECK (valutazione BETWEEN 1 AND 5),
    commento TEXT,
    dataCreazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Utente_Recensore_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    ID_Utente_Recensito_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    CONSTRAINT check_utente_diverso CHECK (ID_Utente_Recensore_FK != ID_Utente_Recensito_FK)
);

-- Tabella CHAT
CREATE TABLE CHAT (
    ID_Chat SERIAL PRIMARY KEY,
    dataChatCreazione TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    tipoChat VARCHAR(50),
    ID_Utente1_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    ID_Utente2_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    CONSTRAINT check_utenti_chat_diversi CHECK (ID_Utente1_FK != ID_Utente2_FK)
);

-- Tabella MESSAGGIO
CREATE TABLE MESSAGGIO (
    ID_Messaggio SERIAL PRIMARY KEY,
    contenutoMessaggio TEXT NOT NULL,
    dataInvio TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Chat_FK INTEGER NOT NULL REFERENCES CHAT(ID_Chat) ON DELETE CASCADE
);

-- Tabella NOTIFICA
CREATE TABLE NOTIFICA (
    ID_Notifica SERIAL PRIMARY KEY,
    tipoNotifica VARCHAR(50) NOT NULL,
    contenuto TEXT NOT NULL,
    isLetta BOOLEAN DEFAULT FALSE,
    dataInvio TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statoNotifica VARCHAR(20) DEFAULT 'ATTIVA',
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE
);

-- Tabella TRANSAZIONE
CREATE TABLE TRANSAZIONE (
    ID_Transazione SERIAL PRIMARY KEY,
    dataInizio TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statoTransazione VARCHAR(20) DEFAULT 'IN_CORSO' CHECK (statoTransazione IN ('IN_CORSO', 'COMPLETATA', 'ANNULLATA')),
    ID_Offerta_FK INTEGER REFERENCES OFFERTA_VENDITA(ID_Offerta) ON DELETE SET NULL,
    ID_Utente_Acquirente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    ID_Utente_Venditore_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    CONSTRAINT check_utenti_transazione_diversi CHECK (ID_Utente_Acquirente_FK != ID_Utente_Venditore_FK)
);

-- Tabella PREFERITI
CREATE TABLE PREFERITI (
    ID_Preferiti SERIAL PRIMARY KEY,
    dataAggiunta TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ID_Utente_FK INTEGER NOT NULL REFERENCES UTENTE(ID_Utente) ON DELETE CASCADE,
    ID_Annuncio_FK INTEGER NOT NULL REFERENCES ANNUNCIO(ID_Annuncio) ON DELETE CASCADE,
    UNIQUE(ID_Utente_FK, ID_Annuncio_FK)
);

