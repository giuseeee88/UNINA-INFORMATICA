-- Funzione per verificare che un utente non faccia offerte sui propri annunci
CREATE OR REPLACE FUNCTION check_offerta_proprio_annuncio()
RETURNS TRIGGER AS $$
BEGIN
    IF EXISTS (
        SELECT 1 FROM ANNUNCIO 
        WHERE ID_Annuncio = NEW.ID_Annuncio_FK 
        AND ID_Utente_FK = NEW.ID_Utente_FK
    ) THEN
        RAISE EXCEPTION 'Un utente non può fare offerte sui propri annunci';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Trigger per OFFERTA_VENDITA
CREATE TRIGGER trigger_check_offerta_vendita
BEFORE INSERT OR UPDATE ON OFFERTA_VENDITA
FOR EACH ROW EXECUTE FUNCTION check_offerta_proprio_annuncio();

-- Trigger per REGALO
CREATE TRIGGER trigger_check_regalo
BEFORE INSERT OR UPDATE ON REGALO
FOR EACH ROW EXECUTE FUNCTION check_offerta_proprio_annuncio();

-- Trigger per OFFERTA_SCAMBIO
CREATE TRIGGER trigger_check_scambio
BEFORE INSERT OR UPDATE ON OFFERTA_SCAMBIO
FOR EACH ROW EXECUTE FUNCTION check_offerta_proprio_annuncio();

-- Funzione per aggiornare lo stato dell'annuncio quando un'offerta viene accettata
CREATE OR REPLACE FUNCTION aggiorna_stato_annuncio_su_accettazione()
RETURNS TRIGGER AS $$
DECLARE
    id_annuncio INTEGER;
BEGIN
    -- Recupera l'ID dell'annuncio dall'offerta
    IF TG_TABLE_NAME = 'OFFERTA_ACCETTATA' THEN
        SELECT ID_Annuncio_FK INTO id_annuncio
        FROM OFFERTA_VENDITA
        WHERE ID_Offerta = NEW.ID_Offerta_FK;
    ELSIF TG_TABLE_NAME = 'REGALO_ACCETTATO' THEN
        SELECT ID_Annuncio_FK INTO id_annuncio
        FROM REGALO
        WHERE ID_Regalo = NEW.ID_Regalo_FK;
    ELSIF TG_TABLE_NAME = 'SCAMBIO_ACCETTATO' THEN
        SELECT ID_Annuncio_FK INTO id_annuncio
        FROM OFFERTA_SCAMBIO
        WHERE ID_Scambio = NEW.ID_Scambio_FK;
    END IF;
    
    -- Aggiorna lo stato dell'annuncio
    UPDATE ANNUNCIO
    SET statoAnnuncio = 'COMPLETATO'
    WHERE ID_Annuncio = id_annuncio;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Trigger per aggiornare lo stato annuncio
CREATE TRIGGER trigger_aggiorna_annuncio_offerta_accettata
AFTER INSERT ON OFFERTA_ACCETTATA
FOR EACH ROW EXECUTE FUNCTION aggiorna_stato_annuncio_su_accettazione();

CREATE TRIGGER trigger_aggiorna_annuncio_regalo_accettato
AFTER INSERT ON REGALO_ACCETTATO
FOR EACH ROW EXECUTE FUNCTION aggiorna_stato_annuncio_su_accettazione();

CREATE TRIGGER trigger_aggiorna_annuncio_scambio_accettato
AFTER INSERT ON SCAMBIO_ACCETTATO
FOR EACH ROW EXECUTE FUNCTION aggiorna_stato_annuncio_su_accettazione();

